<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.chatvibe.module.user.mapper.UserMapper">

    <!-- 通用结果映射 -->
    <resultMap id="UserResultMap" type="com.chatvibe.module.user.entity.User">
        <id column="id" property="id"/>
        <result column="email" property="email"/>
        <result column="password" property="password"/>
        <result column="nickname" property="nickname"/>
        <result column="avatar" property="avatar"/>
        <result column="bio" property="bio"/>
        <result column="status" property="status"/>
        <result column="role" property="role"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
        <result column="deleted" property="deleted"/>
    </resultMap>

    <!-- 按ID批量查询用户(仅展示字段) -->
    <select id="selectByIdsIn" resultMap="UserResultMap">
        SELECT id, email, nickname, avatar, bio, status, role, created_at
        FROM `user`
        WHERE deleted = 0
        AND id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </select>

    <update id="incrLoginVersionAndSetOnline">
        UPDATE `user`
        SET login_version = IFNULL(login_version, 0) + 1, status = #{status}
        WHERE id = #{userId} AND deleted = 0
    </update>

    <select id="selectLoginVersion" resultType="java.lang.Integer">
        SELECT login_version FROM `user` WHERE id = #{userId} AND deleted = 0
    </select>

    <!-- 根据邮箱查询用户 -->
    <select id="findByEmail" resultMap="UserResultMap">
        SELECT * FROM `user`
        WHERE deleted = 0 AND email = #{email}
        LIMIT 1
    </select>

    <!-- 根据关键字搜索用户 -->
    <select id="searchUsers" resultMap="UserResultMap">
        SELECT id, email, nickname, avatar, bio, status, role, created_at
        FROM `user`
        WHERE deleted = 0
          AND (nickname LIKE CONCAT('%', #{keyword}, '%')
            OR email LIKE CONCAT('%', #{keyword}, '%'))
        ORDER BY id DESC
        LIMIT 50
    </select>

</mapper>
