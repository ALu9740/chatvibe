# ============================================================
# ChatVibe Backend 环境变量配置模板
# ============================================================
# 使用方式（三选一）：
#   1. IntelliJ IDEA: 安装 EnvFile 插件，在 Run Configuration 中勾选 .env 文件
#   2. 命令行: source .env && mvn spring-boot:run
#   3. 在 IDE 的 Run Configuration > Environment Variables 中逐条填入
# ============================================================

# ---------- 数据库 ----------
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DB=chatvibe
MYSQL_USER=root
MYSQL_PASSWORD=你的MySQL密码

# ---------- Redis ----------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=你的Redis密码
REDIS_DB=5

# ---------- 邮件服务 (163邮箱) ----------
# 密码为邮箱授权码，非登录密码。在 163 邮箱设置中开启 SMTP 获取
MAIL_USERNAME=你的邮箱@163.com
MAIL_PASSWORD=你的163邮箱授权码

# ---------- MQ ----------
RABBITMQ_HOST=你的MQ地址
RABBITMQ_PORT=5672
RABBITMQ_USER=你的MQ账号
RABBITMQ_PASSWORD=你的MQ密码

# ---------- MinIO 对象存储 ----------
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=你在MinIO的账号
MINIO_SECRET_KEY=你在MinIO的密码
MINIO_BUCKET=chatvibe
MINIO_URL_PREFIX=/minio

# ---------- JWT ----------
# 生产环境务必修改为随机强密钥（至少 256 bits）
JWT_SECRET=请修改为你的JWT密钥至少256位

# ---------- AI 服务 ----------
# 提供商: qwen（阿里云百炼）| ollama（本地）| openai
AI_PROVIDER=qwen

# 阿里云百炼（DashScope）
# 获取 API Key: https://bailian.console.aliyun.com/ -> 模型广场 -> API-KEY 管理
QWEN_API_KEY=你的阿里云百炼API Key
QWEN_MODEL=qwen3.6-max-preview

# OpenAI（可选）
# AI_API_KEY=your-openai-api-key
# AI_API_BASE=https://api.openai.com/v1/chat/completions
# AI_MODEL=gpt-4o-mini

# Ollama 本地（可选）
# OLLAMA_URL=http://localhost:11434/api/chat
# OLLAMA_MODEL=deepseek-r1:8b

# ---------- SSL 证书（开发环境 HTTPS）----------
# 开发环境使用 mkcert 生成的本地证书，放在 src/main/resources/ssl/ 目录下
# 证书文件已被 .gitignore 忽略，需自行生成
# 生成方式: mkcert chatvibe.icu localhost 127.0.0.1 ::1
SSL_ENABLED=true
SSL_CERT_PATH=classpath:ssl/chatvibe.icu+3.pem
SSL_KEY_PATH=classpath:ssl/chatvibe.icu+3-key.pem

