# ============================================================
# ChatVibe 根目录 .gitignore
# ============================================================

# === 环境变量文件（包含敏感信息，不上传） ===
.env
*.env.local
!.env.example
!.env.development
!.env.production

# === SSL 证书 / 密钥文件 ===
*.pem
*.key
*.crt
*.p12
*.jks

# === IDE 配置 ===
.idea/
.vscode/
*.iml
*.ipr
*.iws
*.sw?

# === 操作系统文件 ===
.DS_Store
Thumbs.db
Desktop.ini

# === 临时文件 ===
*.tmp
*.bak
*.log

# === 文档 / 部署配置（非代码，不上传） ===
.trae/
deploy/
*.pdf

# === 上传的文件 ===
uploads/
