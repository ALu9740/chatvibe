# ============================================================
# ChatVibe Frontend 环境变量配置模板
# ============================================================

# ---------- 开发服务器配置 ----------
# 开发服务器监听的主机名（如需局域网访问设为 0.0.0.0）
# VITE_DEV_HOST=localhost

# 后端代理目标地址（开发环境）
# VITE_PROXY_TARGET=https://localhost:8080

# ---------- SSL 证书（开发环境 HTTPS）----------
# 开发环境使用 mkcert 生成的本地证书，放在 frontend/ssl/ 目录下
# 证书文件已被 .gitignore 忽略，需自行生成
# 生成方式: mkcert chatvibe.icu localhost 127.0.0.1 ::1
# SSL_ENABLED=true
# SSL_CERT_PATH=./ssl/chatvibe.icu+3.pem
# SSL_KEY_PATH=./ssl/chatvibe.icu+3-key.pem

# ---------- API 配置 ----------
# 开发环境 API 地址（.env.development 中已配置）
# VITE_API_BASE=https://localhost:8080/api
# VITE_WS_URL=https://localhost:8080/ws-chat

# 生产环境 API 地址（.env.production 中已配置）
# VITE_API_BASE=/api
# VITE_WS_URL=/ws-chat
