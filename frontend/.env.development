# 开发环境
# 后端 API 地址（直连后端，不通过 Vite proxy）
VITE_API_BASE=https://localhost:8080/api
VITE_WS_URL=https://localhost:8080/ws-chat

# 后端代理目标地址（vite.config.ts proxy 使用，当 VITE_API_BASE 为相对路径时生效）
VITE_PROXY_TARGET=https://localhost:8080

# 开发服务器主机（默认 localhost，如需局域网访问设为 0.0.0.0）
VITE_DEV_HOST=localhost

# SSL 证书开关（设为 false 可禁用 HTTPS 开发服务器）
SSL_ENABLED=true
